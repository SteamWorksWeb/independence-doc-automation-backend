// =============================================================================
// THE INDEPENDENCE LAW FIRM — PRISMA DATA VAULT
// schema.prisma
//
// Architecture decisions:
//
//   1. ABSOLUTE DATA ISOLATION — No generic "User" table.
//      Lawyers and Clients are distinct models with distinct auth flows,
//      distinct credential columns, and distinct business logic.
//      They cannot be confused at the database or application level.
//
//   2. UUID PRIMARY KEYS — All IDs use @default(uuid()).
//      Sequential integers expose record counts and enable enumeration attacks.
//      UUIDs are opaque and safe to include in URLs.
//
//   3. REFERENTIAL INTEGRITY — Every Client is assigned to exactly one Lawyer.
//      Cascading behaviour is set to Restrict (no orphaned clients on lawyer
//      deletion). The application layer must reassign clients before removing
//      a lawyer account.
//
//   4. INDEXES — Added on all high-frequency query paths:
//      - Email lookups (login, duplicate-check) on both models
//      - lawyerId on Client (dashboard queries, case aggregations)
//      - verificationToken on Client (token lookup during email verification)
//      - clientId on Message (fetch all messages for a given client)
//
//   5. SNAKE_CASE TABLE NAMES — @@map() ensures DB tables use Postgres
//      convention ("lawyers", "clients", "messages") while Prisma models use PascalCase.
//
//   6. MESSAGING — The Message model is a 1-to-many from Client (required) and
//      an optional 1-to-many from Lawyer. onDelete: Cascade on Client means
//      messages are auto-removed if the client record is deleted.
//
// ─────────────────────────────────────────────────────────────────────────────
// STOP: Do NOT run `prisma migrate dev` without explicit approval.
//       Review this schema first, then confirm before any migration.
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Connection URL is configured in prisma.config.ts (Prisma 7 convention).
  // Set DATABASE_URL in your .env file.
}

// =============================================================================
// LAWYER
//
// The authenticated administrator/attorney.
// Admin credentials live in environment variables (ADMIN_PASSWORD_HASH) for the
// Next.js admin gateway. This model stores Lawyer identity for the backend API —
// enabling future multi-lawyer support as the firm scales.
//
// One Lawyer → Many Clients (1:N)
// =============================================================================

model Lawyer {
  // ── Identity ───────────────────────────────────────────────────────────────
  id    String @id @default(uuid())
  name  String
  email String @unique

  // ── Credentials ────────────────────────────────────────────────────────────
  // bcrypt hash (cost 12). NEVER store plain-text passwords.
  passwordHash String

  // ── Relations ──────────────────────────────────────────────────────────────
  // A Lawyer supervises many Clients.
  // onDelete: Restrict prevents accidental orphaning of Client records.
  clients      Client[]
  invitations  Invitation[]
  // Messages sent by this lawyer to any of their clients.
  messages     Message[]

  // ── Timestamps ─────────────────────────────────────────────────────────────
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Indexes ────────────────────────────────────────────────────────────────
  // Email index: fast login lookups + duplicate-registration checks.
  @@index([email])
  // ── Table name ─────────────────────────────────────────────────────────────
  @@map("lawyers")
}

// =============================================================================
// CLIENT
//
// A firm client who has registered for the secure portal.
// Clients are ALWAYS associated with one Lawyer (lawyerId is required).
// A Client cannot exist without an assigned Lawyer.
//
// The verification loop:
//   1. Client registers → isVerified: false, verificationToken set
//   2. Client clicks email link → token matched + expiry checked
//   3. Backend sets isVerified: true, clears verificationToken + verificationExpires
//   4. Client can now log in
// =============================================================================

model Client {
  // ── Identity ───────────────────────────────────────────────────────────────
  id    String @id @default(uuid())
  name  String
  email String @unique

  // ── Credentials ────────────────────────────────────────────────────────────
  // bcrypt hash (cost 12). NEVER store plain-text passwords.
  passwordHash String

  // ── Verification state ─────────────────────────────────────────────────────
  // isVerified: blocked from logging in until email is confirmed.
  isVerified Boolean @default(false)

  // verificationToken: HMAC-SHA256 hash of the UUID sent in the email link.
  // The raw token travels ONLY in the email URL — never stored here.
  // Null once verification is complete.
  verificationToken String?

  // verificationExpires: UTC expiry of the verification token (default: +24h).
  // Null once verification is complete.
  verificationExpires DateTime?

  // ── Pipeline status ──────────────────────────────────────────────────────────
  // Tracks the client through the admin pipeline. Valid values:
  //   "Intake Pending"   — Default for new clients; intake not yet reviewed
  //   "Ready for Review" — Intake complete, awaiting lawyer review
  //   "Approved"         — Case approved for filing
  //   "Rejected"         — Case not accepted
  status String @default("Intake Pending")

  // ── Lawyer assignment ──────────────────────────────────────────────────────
  // Every client must be assigned to a supervising lawyer.
  lawyerId String
  lawyer   Lawyer @relation(fields: [lawyerId], references: [id], onDelete: Restrict)

  // ── Intake profile (1-to-1) ────────────────────────────────────────────────
  // Created when the client begins the onboarding flow.
  // Null until the client starts intake.
  intakeProfile IntakeProfile?

  // ── Messages (1-to-many) ───────────────────────────────────────────────────
  // All messages in this client's conversation thread.
  messages      Message[]

  // ── Timestamps ─────────────────────────────────────────────────────────────
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Indexes ────────────────────────────────────────────────────────────────
  // Email: fast login lookups + duplicate-registration checks.
  @@index([email])
  // lawyerId: fast dashboard queries — "show all clients for lawyer X".
  @@index([lawyerId])
  // verificationToken: fast token lookup during email verification flow.
  @@index([verificationToken])
  // ── Table name ─────────────────────────────────────────────────────────────
  @@map("clients")
}

// =============================================================================
// INTAKE PROFILE
//
// A 1-to-1 extension of Client storing DOJ-aligned bankruptcy intake data.
// Modelled after the official undue-hardship determination form fields.
// Created when a client begins the onboarding flow; updated on every step save.
// Supports partial saves — all fields are optional except the clientId FK.
//
// isCompleted: true signals the client has submitted the final intake step.
//              The lawyer dashboard uses this flag to identify cases ready
//              for review.
//
// onDelete: Cascade — intake data is automatically removed if the Client
//           record is deleted. No orphaned intake rows.
//
// ⚠ SECURITY NOTE: The `ssn` field stores plain text for MVP only.
//   Before production launch this MUST be encrypted at rest using AES-256
//   (e.g., via pgcrypto or application-layer encryption before Prisma write).
// =============================================================================

model IntakeProfile {
  id String @id @default(uuid())

  // ── 1-to-1 link to Client ─────────────────────────────────────────────────
  // @unique enforces the 1-to-1 constraint at the database level.
  clientId String @unique
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  // ── Personal & Household ───────────────────────────────────────────────────
  dob           String? // MM/DD/YYYY
  ssn           String? // ⚠ Encrypt before production — see note above
  county        String?
  phone         String?
  address       String?
  householdSize Int     @default(0)

  // ── Health & Employment ────────────────────────────────────────────────────
  hasDisability   Boolean @default(false)
  isEmployed      Boolean @default(false)
  unemployed5of10 Boolean @default(false) // Unemployed 5 of last 10 years (means test)
  monthlyIncome   Float?

  // ── Assets ────────────────────────────────────────────────────────────────
  housingStatus   String? // "Own" | "Rent"
  hasCar          Boolean @default(false)
  hasRetirement   Boolean @default(false)
  expectingRefund Boolean @default(false)

  // ── Monthly Expenses (Itemized per DOJ undue-hardship form) ───────────────
  expFood         Float?
  expHousekeeping Float?
  expApparel      Float?
  expPersonalCare Float?
  expHousing      Float?
  expUtilities    Float?
  expTransportGas Float?
  expCarInsurance Float?

  // ── Education & Debt ───────────────────────────────────────────────────────
  totalDebt       Float?
  studentLoanDebt Float?
  schoolsHistory  String? @db.Text // School names, degrees, years attended

  // ── Case narrative ─────────────────────────────────────────────────────────
  hardshipNotes   String? @db.Text
  unmetBasicNeeds String? @db.Text

  // ── Completion flag ────────────────────────────────────────────────────────
  // Set to true when the client submits the final step of the intake form.
  // Lawyers filter on isCompleted: true to find cases ready for review.
  isCompleted Boolean @default(false)

  // ── Timestamps ─────────────────────────────────────────────────────────────
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Table name ─────────────────────────────────────────────────────────────
  @@map("intake_profiles")
}

// =============================================================================
// INVITATION
//
// The "Velvet Rope" — no open registration. An Admin/Lawyer must invite a
// client via email before they can register. Each invitation record holds a
// secure crypto token that is embedded in the invite link.
//
// Flow:
//   1. Lawyer POSTs to /api/v1/admin/invites with client email
//   2. Backend generates a crypto token, saves Invitation, logs invite link
//   3. Client clicks link with ?token=<token>
//   4. Registration endpoint validates token against Invitation table
//   5. On successful registration, isUsed is set to true (single-use)
//
// Token security:
//   - 32-byte random hex token (crypto.randomBytes) — 256 bits of entropy.
//   - Token is unique-indexed — O(1) lookup, no collisions.
//   - Expires after 7 days from creation.
//   - Single-use: isUsed flag prevents replay.
//   - Email must match: even a valid token rejects if the registrant provides
//     a different email address.
// =============================================================================

model Invitation {
  // ── Identity ───────────────────────────────────────────────────────────────
  id    String @id @default(uuid())

  // ── Invite target ──────────────────────────────────────────────────────────
  // The email address of the client being invited.
  email String

  // ── Secure token ───────────────────────────────────────────────────────────
  // 64-char hex string (32 bytes). Embedded in the invite link URL.
  token String @unique

  // ── Expiry ─────────────────────────────────────────────────────────────────
  // UTC timestamp — invite links are valid for 7 days after creation.
  expiresAt DateTime

  // ── Usage flag ─────────────────────────────────────────────────────────────
  // Set to true after the client successfully registers using this invite.
  // Prevents the same invitation from being used to create multiple accounts.
  isUsed Boolean @default(false)

  // ── Timestamps ────────────────────────────────────────────────────────────
  createdAt DateTime @default(now())

  // ── Lawyer relation ───────────────────────────────────────────────────────
  // The lawyer who created this invitation.
  // Used at client registration to satisfy Client.lawyerId (non-nullable).
  lawyerId  String
  lawyer    Lawyer   @relation(fields: [lawyerId], references: [id], onDelete: Restrict)

  // ── Indexes ───────────────────────────────────────────────────────────────
  // Email index: lookup invitations by client email address.
  @@index([email])
  @@index([lawyerId])

  // ── Table name ────────────────────────────────────────────────────────────
  @@map("invitations")
}

// =============================================================================
// MESSAGE
//
// A single message in the Lawyer ↔ Client secure conversation thread.
//
// senderType: discriminator string — either "LAWYER" or "CLIENT".
//   This lets the frontend render messages on the correct side of the UI
//   without a join, and avoids a polymorphic union type on sender.
//
// clientId (required): every message belongs to exactly one client thread.
//   onDelete: Cascade — messages are removed if the client is deleted.
//
// lawyerId (optional): populated when senderType = "LAWYER".
//   Null when senderType = "CLIENT" (client-originated messages).
//   onDelete: SetNull — if a lawyer is ever removed, their messages are
//   preserved in the thread (clientId still links them to the case).
//
// Ordering: always query ORDER BY createdAt ASC to render chronologically.
// =============================================================================

model Message {
  // ── Identity ───────────────────────────────────────────────────────────────
  id String @id @default(uuid())

  // ── Content ────────────────────────────────────────────────────────────────
  content    String   @db.Text

  // ── Sender discriminator ────────────────────────────────────────────────────
  // Valid values: "LAWYER" | "CLIENT"
  senderType String

  // ── Client relation (required) ─────────────────────────────────────────────
  // Every message belongs to exactly one client conversation thread.
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  // ── Lawyer relation (optional) ─────────────────────────────────────────────
  // Populated only when senderType = "LAWYER".
  // SetNull preserves message history if a lawyer account is removed.
  lawyerId String?
  lawyer   Lawyer? @relation(fields: [lawyerId], references: [id], onDelete: SetNull)

  // ── Timestamps ─────────────────────────────────────────────────────────────
  createdAt DateTime @default(now())

  // ── Indexes ────────────────────────────────────────────────────────────────
  // clientId: primary query path — fetch all messages for a given client thread.
  @@index([clientId])
  // clientId + createdAt: supports paginated chronological thread queries.
  @@index([clientId, createdAt])

  // ── Table name ─────────────────────────────────────────────────────────────
  @@map("messages")
}
