# ============================================================
# THE INDEPENDENCE LAW FIRM — NODE.JS BACKEND API
# Environment Variables — Copy to .env and fill in values
# NEVER commit .env to version control
# ============================================================

# ── Server ───────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Database (PostgreSQL) ─────────────────────────────────────
# Used by Prisma for all DB operations.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://postgres:password@localhost:5432/independence_law?schema=public

# ── API Authentication ────────────────────────────────────────
# This token is verified for every incoming request from the Next.js frontend.
# Must match AWS_API_SECRET in the Next.js .env.local.
# Generate with: openssl rand -base64 48
API_BEARER_TOKEN=your-backend-bearer-token-minimum-48-chars

# ── JWT (Client Sessions) ─────────────────────────────────────
# Signs JWT tokens issued to verified clients after login.
# MUST be different from the Next.js frontend NEXTAUTH_SECRET.
# Generate with: openssl rand -base64 32
JWT_SECRET=your-backend-jwt-secret-minimum-32-chars
JWT_EXPIRES_IN=7d

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# In production: https://portal.theindependencelaw.com
CORS_ORIGINS=http://localhost:3000

# ── Security Checklist ───────────────────────────────────────
# Before deploying to AWS, confirm:
#   ✅ DATABASE_URL      — points to production Postgres (RDS/Supabase)
#   ✅ API_BEARER_TOKEN  — matches AWS_API_SECRET in Next.js Vercel env
#   ✅ JWT_SECRET        — unique, NOT shared with frontend secrets
#   ✅ NODE_ENV          — set to "production"
#   ✅ CORS_ORIGINS      — set to exact Vercel deployment URL(s)
